<Page x:Class="EroMangaManagerHttpApiClient.ConnectPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24" VerticalAlignment="Center">
        <StackPanel Spacing="16">

            <TextBlock Text="连接到本子管理器"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8" />

            <TextBlock Text="选择桌面端的 IP 地址"
                       Foreground="Gray"
                       HorizontalAlignment="Center" />

            <!-- IP 地址 -->
            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                <muxc:NumberBox Value="192" IsEnabled="False" Minimum="0" Maximum="255"
                                Width="70" TextAlignment="Center" FontSize="16"
                                SpinButtonPlacementMode="Compact" />
                <TextBlock Text="." VerticalAlignment="Center" FontSize="20" FontWeight="Bold" />
                <muxc:NumberBox Value="168" IsEnabled="False" Minimum="0" Maximum="255"
                                Width="70" TextAlignment="Center" FontSize="16"
                                SpinButtonPlacementMode="Compact" />
                <TextBlock Text="." VerticalAlignment="Center" FontSize="20" FontWeight="Bold" />
                <muxc:NumberBox x:Name="nbIP3" Value="1" Minimum="0" Maximum="255"
                                Width="70" TextAlignment="Center" FontSize="16" SmallChange="1"
                                SpinButtonPlacementMode="Compact" />
                <TextBlock Text="." VerticalAlignment="Center" FontSize="20" FontWeight="Bold" />
                <muxc:NumberBox x:Name="nbIP4" Value="1" Minimum="0" Maximum="255"
                                Width="70" TextAlignment="Center" FontSize="16" SmallChange="1"
                                SpinButtonPlacementMode="Compact" />
            </StackPanel>

            <!-- 端口 -->
            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                <TextBlock Text="端口" VerticalAlignment="Center" FontSize="14" Foreground="Gray" Margin="0,0,8,0" />
                <muxc:NumberBox x:Name="nbPort" Value="12965" IsEnabled="False"
                                Minimum="1" Maximum="65535"
                                Width="90" TextAlignment="Center" FontSize="16"
                                SpinButtonPlacementMode="Compact" />
            </StackPanel>

            <!-- 错误提示 -->
            <TextBlock x:Name="txtError"
                       Foreground="Red"
                       Visibility="Collapsed"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center" />

            <!-- 连接按钮 -->
            <Button x:Name="btnConnect"
                    Content="连接"
                    Click="BtnConnect_Click"
                    Background="#0078D4"
                    Foreground="White"
                    FontSize="16"
                    Height="48"
                    CornerRadius="8"
                    HorizontalAlignment="Stretch" />

            <ProgressRing x:Name="progressRing"
                          Visibility="Collapsed"
                          HorizontalAlignment="Center" />

        </StackPanel>
    </Grid>
</Page>
