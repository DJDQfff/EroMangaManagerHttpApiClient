<Page x:Class="EroMangaManagerHttpApiClient.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:EroMangaManagerHttpApiClient"
      xmlns:model="using:EroMangaManager.Core.Models"
      xmlns:viewmodel="using:EroMangaManager.Core.ViewModels"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

        <NavigationView x:Name="navigationview" ItemInvoked="navigationview_ItemInvoked">
        <NavigationView.MenuItemTemplate>
            <DataTemplate x:DataType="viewmodel:MangasGroup">
                <NavigationViewItem Content="{x:Bind  FolderPath}"/>
            </DataTemplate>
        </NavigationView.MenuItemTemplate>
        <NavigationView.Content>
            <GridView x:Name="gridview" IsItemClickEnabled="True" ItemClick="gridview_ItemClick">
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="model:Manga">
                        <Grid Width="150" Height="210" Margin="10" >
                            <Grid.RowDefinitions>

                                <RowDefinition Height="*"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Image Loaded="Image_Loaded" Width="150" Height="200"  Stretch="Fill" Grid.Row="0"/>
                            <TextBlock Text="{x:Bind MangaName}" TextWrapping="Wrap" Margin="0,5,0,0" Grid.Row="1"/>
                        </Grid>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </NavigationView.Content>
    </NavigationView>

</Page>
